#!/bin/bash
set -euo pipefail

# DADA2 Snakemake Pipeline CLI Entry Point
# Usage: run_dada2processing --amplicon 16S-V4 --fastq-dir /path/to/raw --output-dir /path/to/output --email user@umn.edu [--quality good|bad] [--jobs 16]

show_usage() {
    cat << EOF
Usage: run_dada2processing [OPTIONS]

Required arguments:
  --amplicon AMPLICON       Amplicon type: 16S-V4, ITS1, ITS2, 18S-AMF, 18S-V4
  --fastq-dir DIR           Directory containing raw demultiplexed fastq files
  --output-dir DIR          Output directory (will be created if needed)
  --email EMAIL             Email for SLURM notifications
  --platform PLATFORM       Sequencing platform: illumina or aviti
  --project-name NAME       Project name for output file naming

Optional arguments:
  --quality QUALITY         Sequence quality level: good (default) or bad
  --taxonomy-database DB    Override taxonomy database: SILVA, UNITE, PR2, MaarjAM, EukaryomeSSU, EukaryomeITS
  --fwd-primer SEQUENCE     Override forward primer for this amplicon (DNA string)
  --rev-primer SEQUENCE     Override reverse primer for this amplicon (DNA string)
  --fwd-reads-only          Use forward reads only; skip reverse read processing (default: off)
  --skip-otu                Skip OTU clustering pipeline (default: run OTU pipeline)
  --run-itsx                Run ITSx extraction (ITS1/ITS2 only; default: off)
  --otu-cluster-id ID       VSEARCH clustering identity (default: 0.97)
  --mumu-blast-id PCT       BLAST identity % for mumu (default: 94 for 16S-V4, 84 for others)
  --mumu-ratio RATIO        mumu minimum_ratio (default: 100 for 16S-V4, 1 for others)
  --jobs JOBS               Max parallel Snakemake jobs (default: 16)
  --help                    Show this help message

Examples:
  run_dada2processing --amplicon 16S-V4 --fastq-dir /mnt/data/raw_fastqs --output-dir /mnt/output/16s_run --email me@umn.edu --platform illumina --project-name MyProject
  run_dada2processing --amplicon ITS2 --fastq-dir ./fastqs --output-dir ./output --email me@umn.edu --platform aviti --project-name ITS_Study --quality bad
  run_dada2processing --amplicon 16S-V4 --fastq-dir ./fastqs --output-dir ./output --email me@umn.edu --platform illumina --project-name MyProject --taxonomy-database UNITE
EOF
    exit 1
}

# Defaults
QUALITY="good"
PLATFORM=""
JOBS=16
AMPLICON=""
FASTQ_DIR=""
OUTPUT_DIR=""
EMAIL=""
PROJECT_NAME=""
TAXONOMY_DB_OVERRIDE=""
FWD_PRIMER_OVERRIDE=""
REV_PRIMER_OVERRIDE=""
FWD_READS_ONLY=0
SKIP_OTU=0
RUN_ITSX=0
OTU_CLUSTER_ID="0.97"
MUMU_BLAST_ID=""
MUMU_RATIO=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --amplicon)
            AMPLICON="$2"
            shift 2
            ;;
        --fastq-dir)
            FASTQ_DIR="$2"
            shift 2
            ;;
        --output-dir)
            OUTPUT_DIR="$2"
            shift 2
            ;;
        --email)
            EMAIL="$2"
            shift 2
            ;;
        --quality)
            QUALITY="$2"
            shift 2
            ;;
        --platform)
            PLATFORM="$2"
            shift 2
            ;;
        --jobs)
            JOBS="$2"
            shift 2
            ;;
        --taxonomy-database)
            TAXONOMY_DB_OVERRIDE="$2"
            shift 2
            ;;
        --fwd-primer)
            FWD_PRIMER_OVERRIDE="$2"
            shift 2
            ;;
        --rev-primer)
            REV_PRIMER_OVERRIDE="$2"
            shift 2
            ;;
        --project-name)
            PROJECT_NAME="$2"
            shift 2
            ;;
        --fwd-reads-only)
            FWD_READS_ONLY=1
            shift 1
            ;;
        --skip-otu)
            SKIP_OTU=1
            shift 1
            ;;
        --run-itsx)
            RUN_ITSX=1
            shift 1
            ;;
        --otu-cluster-id)
            OTU_CLUSTER_ID="$2"
            shift 2
            ;;
        --mumu-blast-id)
            MUMU_BLAST_ID="$2"
            shift 2
            ;;
        --mumu-ratio)
            MUMU_RATIO="$2"
            shift 2
            ;;
        --help)
            show_usage
            ;;
        *)
            echo "Unknown option: $1"
            show_usage
            ;;
    esac
done

# Validate required arguments
if [[ -z "$AMPLICON" || -z "$FASTQ_DIR" || -z "$OUTPUT_DIR" || -z "$EMAIL" || -z "$PLATFORM" || -z "$PROJECT_NAME" ]]; then
    echo "Error: Missing required arguments"
    show_usage
fi

# Validate amplicon type
valid_amplicons=("16S-V4" "ITS1" "ITS2" "18S-AMF" "18S-V4")
if [[ ! " ${valid_amplicons[@]} " =~ " ${AMPLICON} " ]]; then
    echo "Error: Invalid amplicon type '${AMPLICON}'"
    echo "Valid options: ${valid_amplicons[*]}"
    exit 1
fi

# Resolve mumu defaults based on amplicon type
if [[ -z "$MUMU_BLAST_ID" ]]; then
    [[ "$AMPLICON" == "16S-V4" ]] && MUMU_BLAST_ID="94" || MUMU_BLAST_ID="84"
fi
if [[ -z "$MUMU_RATIO" ]]; then
    [[ "$AMPLICON" == "16S-V4" ]] && MUMU_RATIO="100" || MUMU_RATIO="1"
fi

# Validate quality
if [[ "$QUALITY" != "good" && "$QUALITY" != "bad" ]]; then
    echo "Error: Quality must be 'good' or 'bad'"
    exit 1
fi

# Validate platform
if [[ "$PLATFORM" != "illumina" && "$PLATFORM" != "aviti" ]]; then
    echo "Error: Platform must be 'illumina' or 'aviti'"
    exit 1
fi

# Validate taxonomy database override
if [[ -n "$TAXONOMY_DB_OVERRIDE" ]]; then
    valid_dbs=("SILVA" "UNITE" "PR2" "MaarjAM" "EukaryomeSSU" "EukaryomeITS")
    if [[ ! " ${valid_dbs[@]} " =~ " ${TAXONOMY_DB_OVERRIDE} " ]]; then
        echo "Error: Invalid taxonomy database '${TAXONOMY_DB_OVERRIDE}'"
        echo "Valid options: ${valid_dbs[*]}"
        exit 1
    fi
fi

# Check fastq directory exists
if [[ ! -d "$FASTQ_DIR" ]]; then
    echo "Error: Fastq directory does not exist: $FASTQ_DIR"
    exit 1
fi

# Check for fastq files
if ! ls "$FASTQ_DIR"/*_R1_001.fastq.gz &>/dev/null; then
    echo "Error: No fastq files found in $FASTQ_DIR (looking for *_R1_001.fastq.gz)"
    exit 1
fi

echo ""
echo "-<->-<->-<->-<->-<->-<->-<->-<->-<->-<->-<->-"
echo "-=-=-=-=-           DADA2           -=-=-=-=-"
echo "-=-=-=-=-        PROCESSING         -=-=-=-=-"
echo "-=-=-=-=-         PIPELINE          -=-=-=-=-"
echo "-<->-<->-<->-<->-<->-<->-<->-<->-<->-<->-<->-"
echo ""

echo "Setting up directories and writing SLURM script..."

# Create output directory structure
mkdir -p "$OUTPUT_DIR"/{00_raw,logs}
OUTPUT_DIR=$(cd "$OUTPUT_DIR" && pwd)

# Detect pipeline root directory
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
PIPELINE_DIR="$(dirname "$SCRIPT_DIR")"

# Create 00_raw directory with symlinks
echo "Setting up synthetic links to fastq files..."
cd "$OUTPUT_DIR/00_raw"
# Create symlinks for both _L001_ and non-_L001_ naming conventions
for fastq in "$FASTQ_DIR"/*_R1_001.fastq.gz "$FASTQ_DIR"/*_R2_001.fastq.gz; do
    if [[ -f "$fastq" ]]; then
        ln -sf "$fastq" "$(basename "$fastq")" || true
    fi
done

# Extract sample names from R1 files
# Handle both naming conventions:
# - With lane: ProjectName_SampleName_L001_R1_001.fastq.gz
# - Without lane: ProjectName_SampleName_R1_001.fastq.gz

echo "Parsing fastq sample names..."

SAMPLES=()
for r1_file in *_R1_001.fastq.gz; do
    # Try removing _L001_R1_001.fastq.gz first (with lane number)
    sample_name="${r1_file%_L001_R1_001.fastq.gz}"
    # If that didn't work (name unchanged), try removing just _R1_001.fastq.gz (without lane)
    if [[ "$sample_name" == "$r1_file" ]]; then
        sample_name="${r1_file%_R1_001.fastq.gz}"
    fi
    SAMPLES+=("$sample_name")
done

if [[ ${#SAMPLES[@]} -eq 0 ]]; then
    echo "Error: No samples found"
    exit 1
fi

echo "Found ${#SAMPLES[@]} samples: ${SAMPLES[*]}"

# Set up file paths (needed before SLURM script creation for placeholder replacement)
CONFIG_FILE="$OUTPUT_DIR/config.yaml"
SLURM_SCRIPT="$OUTPUT_DIR/submit_job.sh"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
LOG_FILE="$OUTPUT_DIR/logs/snakemake_${TIMESTAMP}.log"

cat > "$SLURM_SCRIPT" << 'SCRIPT'
#!/bin/bash -l
#SBATCH --time=12:00:00
#SBATCH --ntasks=64
#SBATCH --mem=60gb
#SBATCH --mail-type=ALL
#SBATCH --mail-user=PLACEHOLDER_EMAIL
#SBATCH --job-name=dada2_PLACEHOLDER_AMPLICON
#SBATCH --output=PLACEHOLDER_OUTPUT_DIR/slurm_%j.out
#SBATCH --error=PLACEHOLDER_OUTPUT_DIR/slurm_%j.err

set -euo pipefail

CONFIG_FILE="PLACEHOLDER_CONFIG"
LOG_FILE="PLACEHOLDER_LOG"
PIPELINE_DIR="PLACEHOLDER_PIPELINE_DIR"
JOBS=PLACEHOLDER_JOBS
OUTPUT_DIR="PLACEHOLDER_OUTPUT_DIR"

set +u  # Temporarily disable strict mode for conda/mamba
module load miniforge/24.3
module load cutadapt/5.0
module load snakemake
module load blast-plus/2.13.0-gcc-8.2.0-vo4mr4d 2>/dev/null || true
module load gcc/13.1.0-5z64cho 2>/dev/null || true
CONDA_BASE=$(conda info --base 2>/dev/null) || { echo "ERROR: miniforge not found"; exit 1; }
source "$CONDA_BASE/etc/profile.d/conda.sh"

# Create or use existing dada2 conda environment
DADA2_ENV="dada2_processing_v2"
if conda env list | grep -q "$DADA2_ENV"; then
    echo "Using existing $DADA2_ENV environment..."
else
    echo "Creating $DADA2_ENV environment (this may take several minutes)..."
    ENV_FILE="$PIPELINE_DIR/envs/dada2.yaml"
    if [[ -f "$ENV_FILE" ]]; then
        conda env create -f "$ENV_FILE"
    else
        # Fallback if environment file not found
        echo "WARNING: envs/dada2.yaml not found, using minimal packages..."
        conda create -n $DADA2_ENV -c bioconda -c conda-forge \
            bioconductor-dada2 r-base r-jsonlite r-ggplot2 -y
    fi
fi

conda activate $DADA2_ENV
set -u  # Re-enable strict mode

snakemake \
  --snakefile "$PIPELINE_DIR/Snakefile" \
  --configfile "$CONFIG_FILE" \
  --cores $SLURM_NTASKS \
  --jobs $JOBS \
  --rerun-incomplete \
  --printshellcmds \
  2>&1 | tee "$LOG_FILE"

exit ${PIPESTATUS[0]}
SCRIPT

# Replace placeholders in SLURM script
sed -i.bak "s|PLACEHOLDER_EMAIL|$EMAIL|g" "$SLURM_SCRIPT"
sed -i.bak "s|PLACEHOLDER_AMPLICON|$AMPLICON|g" "$SLURM_SCRIPT"
sed -i.bak "s|PLACEHOLDER_CONFIG|$CONFIG_FILE|g" "$SLURM_SCRIPT"
sed -i.bak "s|PLACEHOLDER_LOG|$LOG_FILE|g" "$SLURM_SCRIPT"
sed -i.bak "s|PLACEHOLDER_OUTPUT_DIR|$OUTPUT_DIR|g" "$SLURM_SCRIPT"
sed -i.bak "s|PLACEHOLDER_PIPELINE_DIR|$PIPELINE_DIR|g" "$SLURM_SCRIPT"
sed -i.bak "s|PLACEHOLDER_JOBS|$JOBS|g" "$SLURM_SCRIPT"
rm -f "$SLURM_SCRIPT.bak"

chmod +x "$SLURM_SCRIPT"

# ==============================================================================
# PRIMER VALIDATION CHECK
# ==============================================================================
echo ""
echo "=========================================="
echo "VALIDATING PRIMERS"
echo "=========================================="
echo ""

# Load required modules for primer validation
set +u  # Temporarily disable strict mode for module loading
module load cutadapt/5.0 || {
  echo "ERROR: Could not load cutadapt/5.0 module"
  exit 1
}
set -u  # Re-enable strict mode

# Determine which primers to validate
VALIDATE_FWD="${FWD_PRIMER_OVERRIDE:-$(
  case "$AMPLICON" in
    16S-V4)  echo "GTGYCAGCMGCCGCGGTAA" ;;
    ITS1)    echo "CTTGGTCATTTAGAGGAAGTAA" ;;
    ITS2)    echo "TCGATGAAGAACGCAGCG" ;;
    18S-AMF) echo "CAGCCGCGGTAATTCCAGCT" ;;
    18S-V4)  echo "TTAAARVGYTCGTAGTYG" ;;
  esac
)}"

VALIDATE_REV="${REV_PRIMER_OVERRIDE:-$(
  case "$AMPLICON" in
    16S-V4)  echo "GGACTACNVGGGTWTCTAAT" ;;
    ITS1)    echo "GCTGCGTTCTTCATCGATGC" ;;
    ITS2)    echo "TCCTCCGCTTATTGATATGC" ;;
    18S-AMF) echo "GAACCCAAACACTTTGGTTTCC" ;;
    18S-V4)  echo "CCGTCAATTHCTTYAART" ;;
  esac
)}"

echo ""
echo "Scanning fastq files for expected primers..."
echo ""

# Run primer check using cutadapt
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
python3 "$SCRIPT_DIR/check_primers_cutadapt.py" "$FASTQ_DIR" "$VALIDATE_FWD" "$VALIDATE_REV" "$AMPLICON" "$OUTPUT_DIR" || {
  echo ""
  echo "ERROR: Primer validation failed"
  echo "Please check that:"
  echo "  1. Python and cutadapt are available (module load cutadapt)"
  echo "  2. FASTQ files exist in $FASTQ_DIR"
  exit 1
}

# Read detected primers from JSON file (saved in output_dir to avoid permission issues)
PRIMER_JSON="$OUTPUT_DIR/.primer_detection.json"
if [[ -f "$PRIMER_JSON" ]]; then
  # Extract detected primers using jq (if available) or python
  if command -v jq &> /dev/null; then
    DETECTED_FWD_NAME=$(jq -r '.fwd_name' "$PRIMER_JSON")
    DETECTED_FWD_SEQ=$(jq -r '.fwd_seq' "$PRIMER_JSON")
    DETECTED_FWD_PCT=$(jq -r '.fwd_pct' "$PRIMER_JSON")
    DETECTED_REV_NAME=$(jq -r '.rev_name' "$PRIMER_JSON")
    DETECTED_REV_SEQ=$(jq -r '.rev_seq' "$PRIMER_JSON")
    DETECTED_REV_PCT=$(jq -r '.rev_pct' "$PRIMER_JSON")
    EXPECTED_FWD_SEQ=$(jq -r '.expected_fwd' "$PRIMER_JSON")
    EXPECTED_REV_SEQ=$(jq -r '.expected_rev' "$PRIMER_JSON")
  else
    # Fallback to python
    DETECTED_FWD_NAME=$(python3 -c "import json; d=json.load(open('$PRIMER_JSON')); print(d.get('fwd_name', ''))")
    DETECTED_FWD_SEQ=$(python3 -c "import json; d=json.load(open('$PRIMER_JSON')); print(d.get('fwd_seq', ''))")
    DETECTED_FWD_PCT=$(python3 -c "import json; d=json.load(open('$PRIMER_JSON')); print(d.get('fwd_pct', 0))")
    DETECTED_REV_NAME=$(python3 -c "import json; d=json.load(open('$PRIMER_JSON')); print(d.get('rev_name', ''))")
    DETECTED_REV_SEQ=$(python3 -c "import json; d=json.load(open('$PRIMER_JSON')); print(d.get('rev_seq', ''))")
    DETECTED_REV_PCT=$(python3 -c "import json; d=json.load(open('$PRIMER_JSON')); print(d.get('rev_pct', 0))")
    EXPECTED_FWD_SEQ=$(python3 -c "import json; d=json.load(open('$PRIMER_JSON')); print(d.get('expected_fwd', ''))")
    EXPECTED_REV_SEQ=$(python3 -c "import json; d=json.load(open('$PRIMER_JSON')); print(d.get('expected_rev', ''))")
  fi

  # Check if detected primers differ from expected and use detected ones if >80% match
  if [[ "$DETECTED_FWD_SEQ" != "$EXPECTED_FWD_SEQ" ]] && (( $(echo "$DETECTED_FWD_PCT > 80" | bc -l) )); then
    echo ""
    echo "=========================================="
    echo "⚠️  PRIMER AUTO-DETECTION: FORWARD"
    echo "=========================================="
    echo "Expected: $EXPECTED_FWD_SEQ"
    echo "Detected: $DETECTED_FWD_NAME ($DETECTED_FWD_PCT%)"
    echo "Sequence: $DETECTED_FWD_SEQ"
    echo ""
    echo "Using detected primer for trimming."
    FWD_PRIMER_OVERRIDE="$DETECTED_FWD_SEQ"
    echo ""
  fi

  if [[ "$DETECTED_REV_SEQ" != "$EXPECTED_REV_SEQ" ]] && (( $(echo "$DETECTED_REV_PCT > 80" | bc -l) )); then
    echo ""
    echo "=========================================="
    echo "⚠️  PRIMER AUTO-DETECTION: REVERSE"
    echo "=========================================="
    echo "Expected: $EXPECTED_REV_SEQ"
    echo "Detected: $DETECTED_REV_NAME ($DETECTED_REV_PCT%)"
    echo "Sequence: $DETECTED_REV_SEQ"
    echo ""

    # Special note for ITS2 with ITS4-Fun
    if [[ "$AMPLICON" == "ITS2" && "$DETECTED_REV_NAME" == "ITS4-Fun" ]]; then
      echo "ℹ️  NOTE: ITS4-Fun is longer than the standard ITS4 primer and is"
      echo "   specifically designed to handle degenerate/variable sequences better."
      echo "   This is expected behavior for ITS2 datasets."
      echo ""
    fi

    echo "Using detected primer for trimming."
    REV_PRIMER_OVERRIDE="$DETECTED_REV_SEQ"
    echo ""
  fi
fi

# Now write config.yaml AFTER primer detection (CONFIG_FILE defined earlier)
cat > "$CONFIG_FILE" << YAML
# DADA2 Pipeline Config
# Auto-generated by run_dada2processing at $(date)

amplicon: "$AMPLICON"
quality: "$QUALITY"
platform: "$PLATFORM"
output_dir: "$OUTPUT_DIR"
email: "$EMAIL"
fastq_dir: "$FASTQ_DIR"
project_name: "$PROJECT_NAME"
taxonomy_db_override: "$TAXONOMY_DB_OVERRIDE"
fwd_primer_override: "$FWD_PRIMER_OVERRIDE"
rev_primer_override: "$REV_PRIMER_OVERRIDE"
fwd_reads_only: "$FWD_READS_ONLY"
skip_otu: "$SKIP_OTU"
run_itsx: "$RUN_ITSX"
otu_cluster_id: "$OTU_CLUSTER_ID"
mumu_blast_id: "$MUMU_BLAST_ID"
mumu_ratio: "$MUMU_RATIO"

samples:
$(for sample in "${SAMPLES[@]}"; do echo "  - $sample"; done)
YAML

echo "Config written to: $CONFIG_FILE"

echo ""
echo "=========================================="
echo "DADA2 Pipeline Ready"
echo "=========================================="
echo "--SETTINGS AND SPECIFICATIONS--"
echo "Amplicon:         $AMPLICON"
echo "Quality:          $QUALITY"
echo "Platform:         $PLATFORM"
echo "Samples:          ${#SAMPLES[@]}"
echo "Project name:     $PROJECT_NAME"
# Display taxonomy database
if [[ -n "$TAXONOMY_DB_OVERRIDE" ]]; then
    echo "Taxonomy DB:      $TAXONOMY_DB_OVERRIDE (override)"
else
    case "$AMPLICON" in
        16S-V4)  echo "Taxonomy DB:      SILVA (default)" ;;
        ITS1|ITS2) echo "Taxonomy DB:      UNITE (default)" ;;
        18S-AMF) echo "Taxonomy DB:      MaarjAM (default)" ;;
        18S-V4)  echo "Taxonomy DB:      PR2 (default)" ;;
    esac
fi
echo ""
echo "--PRIMERS--"
# Resolve and display forward primer (may include auto-detected value)
DISPLAY_FWD="${FWD_PRIMER_OVERRIDE:-$(
  case "$AMPLICON" in
    16S-V4)  echo "GTGYCAGCMGCCGCGGTAA" ;;
    ITS1)    echo "CTTGGTCATTTAGAGGAAGTAA" ;;
    ITS2)    echo "TCGATGAAGAACGCAGCG" ;;
    18S-AMF) echo "CAGCCGCGGTAATTCCAGCT" ;;
    18S-V4)  echo "TTAAARVGYTCGTAGTYG" ;;
  esac
)}"

DISPLAY_REV="${REV_PRIMER_OVERRIDE:-$(
  case "$AMPLICON" in
    16S-V4)  echo "GGACTACNVGGGTWTCTAAT" ;;
    ITS1)    echo "GCTGCGTTCTTCATCGATGC" ;;
    ITS2)    echo "TCCTCCGCTTATTGATATGC" ;;
    18S-AMF) echo "GAACCCAAACACTTTGGTTTCC" ;;
    18S-V4)  echo "CCGTCAATTHCTTYAART" ;;
  esac
)}"

echo "Fwd primer:       $DISPLAY_FWD"
echo "Rev primer:       $DISPLAY_REV"
echo "Forward-only:     $([ "$FWD_READS_ONLY" -eq 1 ] && echo 'yes' || echo 'no')"
echo ""

if [ "$SKIP_OTU" -eq 0 ]; then
    echo "--ASV2OTU SETTINGS--"
    echo "OTU clustering:   ${OTU_CLUSTER_ID} identity"
    echo "ITSx extraction:  $([ "$RUN_ITSX" -eq 1 ] && echo 'enabled' || echo 'disabled')"
    echo "mumu BLAST ID:    ${MUMU_BLAST_ID}%"
    echo "mumu ratio:       ${MUMU_RATIO}"
else
    echo "--Skipping ASV2OTU--"
fi
echo ""
echo "--FILES AND DIRECTORIES--"
echo "Input directory:  $FASTQ_DIR"
echo "Output directory: $OUTPUT_DIR"
echo "Config file:      $CONFIG_FILE"
echo "SLURM script:     $SLURM_SCRIPT"
echo "Log file:         $LOG_FILE"
echo ""

echo ""
echo ""
echo "Run this command to submit the job to the supercomputer:"
echo "  sbatch $SLURM_SCRIPT"
echo ""
echo "=========================================="
